<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>HttpClient metrics for Prometheus.Client</Description>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <RepositoryUrl>https://github.com/prom-client-net/prom-client-httpclient</RepositoryUrl>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Prometheus.Client" Version="6.3.0" />
    <PackageReference Condition="'$(TargetFramework)' == 'net8.0'"
                      Include="Microsoft.Extensions.Http" Version="8.0.1" />
    <PackageReference Condition="'$(TargetFramework)' == 'net10.0'"
                      Include="Microsoft.Extensions.Http" Version="10.0.10" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="$(MSBuildProjectName).Tests, " />
  </ItemGroup>
</Project>
